# --- Gemini (server-side only, never exposed to the client) ---
# Get a key from https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Model id used for analysis. Override here without touching code.
GEMINI_MODEL=gemini-3.5-flash-lite

# --- MongoDB ---
# Used to persist analyses so results have shareable links.
MONGODB_URI=mongodb://127.0.0.1:27017/dermaglow
MONGODB_DB=dermaglow

# --- App ---
# Public base URL, used when building shareable result links.
NEXT_PUBLIC_APP_URL=http://localhost:3000
